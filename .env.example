# === LLM API ===
DEEPSEEK_API_KEY=sk-...                    # https://platform.deepseek.com/
ANTHROPIC_API_KEY=sk-ant-...               # Опционально, для эскалации (MVP: не используется)

# --- GLM / Zhipu ---
# Две платформы. Ключ определяет, какую использовать:
#
# А) open.bigmodel.cn (Китай, нужен китайский телефон) — дефолт в config/models.yaml,
#    ничего дополнительно указывать не надо:
ZHIPU_API_KEY=...
#
# Б) z.ai (международная платная подписка) — раскомментировать 3 строки ниже:
# ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4
# GLM_FLASH_MODEL=glm-4.5-flash
# GLM_EMBEDDING_MODEL=embedding-3           # если z.ai не отдаёт эмбеддинги — дедуп
#                                           # молча деградирует до URL-дедупа, это ок

# === Git / GitHub ===
GH_TOKEN=ghp_...                           # PAT с правами repo + pull-requests
MEDIA_REPO=yuriysklv-hue/media             # Slug репозитория с сайтом
MEDIA_GIT_URL=                             # Опционально; по умолчанию собирается из GH_TOKEN + MEDIA_REPO
MEDIA_SITE_SUBDIR=media-site               # Подпапка где живёт сайт внутри репо

# === Конфигурация ===
DRY_RUN=false                              # true = нет git-операций, файлы только в drafts/
LOG_LEVEL=INFO
