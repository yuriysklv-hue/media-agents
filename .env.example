# === LLM API ===
DEEPSEEK_API_KEY=sk-...                    # https://platform.deepseek.com/
ZHIPU_API_KEY=...                          # https://open.bigmodel.cn/ — см. README, раздел Zhipu
ANTHROPIC_API_KEY=sk-ant-...               # Опционально, для эскалации (MVP: не используется)

# === Git / GitHub ===
GH_TOKEN=ghp_...                           # PAT с правами repo + pull-requests
MEDIA_REPO=yuriysklv-hue/media             # Slug репозитория с сайтом
MEDIA_GIT_URL=                             # Опционально; по умолчанию собирается из GH_TOKEN + MEDIA_REPO
MEDIA_SITE_SUBDIR=media-site               # Подпапка где живёт сайт внутри репо

# === Конфигурация ===
DRY_RUN=false                              # true = нет git-операций, файлы только в drafts/
LOG_LEVEL=INFO
